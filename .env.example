# Copy this file to .env and fill in the values you need.

# --- MongoDB -----------------------------------------------------------
# Local MongoDB (default, works out of the box if you have `mongod` running):
MONGO_URI=mongodb://127.0.0.1:27017/quickhero
# Or an Atlas connection string, e.g.:
# MONGO_URI=mongodb+srv://user:pass@cluster0.mongodb.net/quickhero

# --- Auth ----------------------------------------------------------------
# Any long random string. Changing it logs everyone out.
JWT_SECRET=change-this-to-a-long-random-string

# --- Server ---------------------------------------------------------------
PORT=4000

# --- Google Maps (optional) ------------------------------------------------
# Only needed for the interactive map (live tracking) and admin ETA lookups.
# Without these, the app still works — the map screens will just show a
# friendly "map unavailable" message instead of the live map.
# Browser key (used by the React app — must allow your localhost origin):
VITE_GOOGLE_MAPS_API_KEY=
# Server key (used by the backend for driving-time ETA lookups; can be the
# same key as above as long as it also has the Directions/Routes API enabled):
GOOGLE_MAPS_SERVER_KEY=

# --- Google Sign-In (optional) ---------------------------------------------
# Required for "Continue with Google". Get a client ID from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=
